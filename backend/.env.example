# ==============================================================================
# WISEBOX BACKEND CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
APP_NAME=Wisebox
APP_ENV=local
APP_KEY=
# Generate key with: docker compose exec app php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# Database (MySQL 8)
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wisebox
DB_USERNAME=wisebox
DB_PASSWORD=secret

# ------------------------------------------------------------------------------
# Session (for Admin Panel - uses Redis)
# ------------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ------------------------------------------------------------------------------
# Broadcasting, Filesystem, Queue
# ------------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local  # Change to 's3' for production
QUEUE_CONNECTION=redis

# ------------------------------------------------------------------------------
# Cache (Redis)
# ------------------------------------------------------------------------------
CACHE_STORE=redis

# ------------------------------------------------------------------------------
# Redis Configuration
# ------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Email (Mailpit for local dev)
# ------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@wiseboxinc.com"
MAIL_FROM_NAME="Wisebox"

# ------------------------------------------------------------------------------
# AWS S3 (File Storage for Production)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_DOCUMENTS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------------------
# Stripe (Payment Processing)
# ------------------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Twilio (SMS/OTP)
# ------------------------------------------------------------------------------
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VERIFY_SID=

# ------------------------------------------------------------------------------
# Google OAuth
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ------------------------------------------------------------------------------
# Calendly (Consultation Scheduling)
# ------------------------------------------------------------------------------
CALENDLY_API_KEY=
CALENDLY_BASE_URL=https://api.calendly.com
CALENDLY_WEBHOOK_SECRET=
CALENDLY_BOOKING_URL=
CALENDLY_EVENT_TYPE_URI=

# ------------------------------------------------------------------------------
# Frontend URL (for redirects and CORS)
# ------------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Sanctum Authentication (Token-Based, Stateless)
# ------------------------------------------------------------------------------
# Token prefix (appears in generated tokens, useful for GitHub secret scanning)
SANCTUM_TOKEN_PREFIX=wb_

# Token expiration in minutes (1440 = 24 hours)
SANCTUM_TOKEN_EXPIRATION=1440

# NOTE: SANCTUM_STATEFUL_DOMAINS is intentionally NOT set
# We use token-based auth (not cookie-based) for SPA + API architecture
# This avoids CORS complexity and works across different origins

# ------------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1,http://127.0.0.1:3000,https://wisebox-v2.vercel.app,https://wisebox-fork.vercel.app,https://app.mywisebox.com,https://mywisebox.com

# ------------------------------------------------------------------------------
# Admin Panel Seeded User (for local development)
# ------------------------------------------------------------------------------
ADMIN_NAME="Wisebox Admin"
ADMIN_EMAIL=admin@wisebox.local
ADMIN_PASSWORD=Admin123!

# ------------------------------------------------------------------------------
# Vite (Asset Bundling)
# ------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
