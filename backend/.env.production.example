# ==============================================================================
# WISEBOX BACKEND - PRODUCTION ENVIRONMENT
# ==============================================================================
# Configure via Railway dashboard > Variables (NOT committed to git)
# Copy these keys and fill values in your hosting platform's secrets manager

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME=Wisebox
APP_ENV=production
APP_KEY=                              # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://wisebox-backend-production.up.railway.app
APP_LOCALE=en
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# Logging (production: single file, warnings+)
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ------------------------------------------------------------------------------
# Database (Railway MySQL plugin or external)
# Railway auto-sets: MYSQL_URL, MYSQLDATABASE, MYSQLHOST, MYSQLPORT, etc.
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT:-3306}
DB_DATABASE=${MYSQLDATABASE:-wisebox}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# ------------------------------------------------------------------------------
# Redis (optional: add Railway Redis plugin if needed later)
# Railway auto-sets: REDIS_URL, REDISHOST, REDISPORT, etc.
# For MVP, database drivers work fine without Redis.
# ------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=${REDISHOST:-127.0.0.1}
REDIS_PASSWORD=${REDISPASSWORD:-null}
REDIS_PORT=${REDISPORT:-6379}

# ------------------------------------------------------------------------------
# Session, Cache, Queue
# MVP uses database drivers (no Redis dependency).
# Switch to redis when you add a Redis plugin for better performance.
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=
CACHE_STORE=database
QUEUE_CONNECTION=database
DB_QUEUE_CONNECTION=mysql

# ------------------------------------------------------------------------------
# File Storage (S3 for documents)
# ------------------------------------------------------------------------------
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=wisebox-production
AWS_DOCUMENTS_BUCKET=wisebox-documents
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------------------
# Email (choose one: postmark, ses, resend)
# Postmark recommended: https://postmarkapp.com
# ------------------------------------------------------------------------------
MAIL_MAILER=postmark
POSTMARK_TOKEN=
MAIL_FROM_ADDRESS=noreply@mywisebox.com
MAIL_FROM_NAME=Wisebox

# ------------------------------------------------------------------------------
# Stripe (LIVE keys)
# Get from: https://dashboard.stripe.com/apikeys (toggle Live mode)
# Webhook: https://wisebox-backend-production.up.railway.app/api/v1/webhooks/stripe
# ------------------------------------------------------------------------------
STRIPE_KEY=                           # pk_live_...
STRIPE_SECRET=                        # sk_live_...
STRIPE_WEBHOOK_SECRET=                # whsec_...

# ------------------------------------------------------------------------------
# Google OAuth
# Console: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://wisebox-backend-production.up.railway.app/api/v1/auth/google/callback
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://wisebox-backend-production.up.railway.app/api/v1/auth/google/callback

# ------------------------------------------------------------------------------
# Calendly (optional for MVP, enable when ready)
# Dashboard: https://developer.calendly.com
# Webhook: https://wisebox-backend-production.up.railway.app/api/v1/webhooks/calendly
# ------------------------------------------------------------------------------
CALENDLY_API_KEY=
CALENDLY_BASE_URL=https://api.calendly.com
CALENDLY_WEBHOOK_SECRET=
CALENDLY_BOOKING_URL=
CALENDLY_EVENT_TYPE_URI=

# ------------------------------------------------------------------------------
# Twilio SMS/OTP (optional, enable when ready)
# Console: https://console.twilio.com
# ------------------------------------------------------------------------------
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VERIFY_SID=

# ------------------------------------------------------------------------------
# Frontend (for CORS and email links)
# ------------------------------------------------------------------------------
FRONTEND_URL=https://wisebox-mvp.vercel.app
CORS_ALLOWED_ORIGINS=https://wisebox-mvp.vercel.app

# ------------------------------------------------------------------------------
# Sanctum (token-based auth)
# ------------------------------------------------------------------------------
SANCTUM_TOKEN_PREFIX=wb_
SANCTUM_TOKEN_EXPIRATION=1440

# ------------------------------------------------------------------------------
# Admin Panel (first-run seeding only)
# ------------------------------------------------------------------------------
ADMIN_NAME=Wisebox Admin
ADMIN_EMAIL=admin@wisebox.com
ADMIN_PASSWORD=                       # Strong password, change after first login
