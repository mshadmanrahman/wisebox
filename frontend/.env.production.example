# ==============================================================================
# WISEBOX FRONTEND - PRODUCTION ENVIRONMENT
# ==============================================================================
# Copy to Vercel dashboard > Settings > Environment Variables
# Do NOT commit actual values to git

# Backend API (Railway-hosted Laravel)
NEXT_PUBLIC_API_URL=https://wisebox-backend-production.up.railway.app/api/v1

# Frontend URL (Vercel domain)
NEXT_PUBLIC_APP_URL=https://wisebox-mvp.vercel.app

# Google OAuth (production credentials)
# Register at: https://console.cloud.google.com/apis/credentials
# Add authorized origin: https://wisebox-mvp.vercel.app
# Add redirect URI: https://wisebox-backend-production.up.railway.app/api/v1/auth/google/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Stripe (LIVE publishable key)
# Get from: https://dashboard.stripe.com/apikeys (toggle Live mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Feature Flags
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=true
NEXT_PUBLIC_ENABLE_ASSESSMENT=true

# Analytics (add when ready)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
