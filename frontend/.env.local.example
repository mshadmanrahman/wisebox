# ==============================================================================
# WISEBOX FRONTEND CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend API Connection
# ------------------------------------------------------------------------------
# Base URL for all API requests (must include /api/v1)
# Local: http://localhost:8000/api/v1
# Production: https://api.mywisebox.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ------------------------------------------------------------------------------
# Application URL
# ------------------------------------------------------------------------------
# Used for OAuth callbacks and redirects
# Local: http://localhost:3000
# Production: https://app.mywisebox.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Google OAuth
# ------------------------------------------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
# Required for social login functionality
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ------------------------------------------------------------------------------
# Stripe (Payment Processing)
# ------------------------------------------------------------------------------
# Publishable key (safe to expose in frontend)
# Get from: https://dashboard.stripe.com/apikeys
# Test mode: pk_test_...
# Live mode: pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ------------------------------------------------------------------------------
# Feature Flags (Optional)
# ------------------------------------------------------------------------------
# Uncomment to enable/disable features
# NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=true
# NEXT_PUBLIC_ENABLE_ASSESSMENT=true
# NEXT_PUBLIC_ENABLE_CALENDLY=true

# ------------------------------------------------------------------------------
# Analytics (Optional)
# ------------------------------------------------------------------------------
# Uncomment and add tracking IDs when ready
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_HOTJAR_ID=
# NEXT_PUBLIC_SENTRY_DSN=

# ------------------------------------------------------------------------------
# Development (Optional)
# ------------------------------------------------------------------------------
# Uncomment for development debugging
# NEXT_PUBLIC_DEBUG_MODE=true
# NEXT_PUBLIC_MOCK_API=false
